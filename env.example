# =====================================================================
#  YouTube Job Alert Generator — Environment Configuration
#  Copy this file to ".env" and fill in your actual values.
#  NEVER commit your real .env file to git!
# =====================================================================

# ── Pixabay API (FREE - get key at https://pixabay.com/api/docs/) ──
PIXABAY_API_KEY=your_pixabay_api_key_here

# ── YouTube Upload ─────────────────────────────────────────────────
# Set to "false" to test the pipeline without uploading
YOUTUBE_UPLOAD_ENABLED=true

# Path to your OAuth2 client_secrets.json downloaded from Google Cloud Console
# (Only needed for local dev — GitHub CI uses YOUTUBE_TOKEN_JSON secret)
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json

# ── Pipeline Control ────────────────────────────────────────────────
# Max videos to generate and upload per run (max 4 to stay within YouTube quota)
MAX_VIDEOS_PER_RUN=4

# ── Optional Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
